[configuration]

entry_symbol = "GDExtensionInit"
compatibility_minimum = 4.5

[libraries]
windows.release.x86_64 = "lib/Windows-AMD64/gdlibretro-d.dll"
windows.debug.x86_64 = "lib/Windows-AMD64/gdlibretro-d.dll"
linux.release.x86_64 = "lib/Linux-x86_64/libgdlibretro.so"
linux.debug.x86_64 = "lib/Linux-x86_64/libgdlibretro.so"
macos.release = "lib/Darwin-Universal/libgdlibretro.dylib"
macos.debug = "lib/Darwin-Universal/libgdlibretro.dylib"